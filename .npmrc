# Automatically saves exact versions instead of using caret (^) or tilde (~)
# This makes builds more predictable
save-exact=true

# --- Security & Registry ---
# Point to the official registry (or your private one like Verdaccio/Artifactory)
registry=https://registry.npmjs.org/

# Prevent scripts from running during install (improves security)
# Note: Some packages may require this to be 'false' to build C++ modules
ignore-scripts=true

# --- Logging ---
# Keeps the terminal clean but shows enough info if something breaks
loglevel=warn

# Enforce engines specified in package.json to ensure compatibility
engines-strict=true

# Peer dependencies are a nightmare, let's just ignore them
strict-peer-dependencies=false
