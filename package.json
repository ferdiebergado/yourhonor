{
  "name": "netlify-fullstack",
  "description": "Fullstack typescript application template for deployment to Netlify",
  "author": {
    "email": "ferdiebergado@gmail.com",
    "name": "Ferdinand Saporas Bergado"
  },
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": "22.22.0",
    "npm": "10.9.4",
    "pnpm": "10.33.0"
  },
  "scripts": {
    "dev": "netlify dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "db:create": "sqlite3 local.db < ./init.sql",
    "db:seed": "sqlite3 local.db < ./seed.sql",
    "db": "sqlite3 -init .sqliterc local.db",
    "db:reset": "read -p 'Are you sure you want to reset the DB? (y/n) ' res && [ \"$res\" = \"y\" ] && rm -f local.db && npm run db:create && npm run db:seed",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@benedicte/docx-merge": "0.1.3",
    "@fontsource-variable/oxanium": "5.2.8",
    "@fontsource-variable/public-sans": "5.2.7",
    "@hookform/resolvers": "5.2.2",
    "@libsql/client": "0.17.3",
    "@netlify/edge-functions": "3.0.6",
    "@netlify/functions": "5.2.0",
    "@remixicon/react": "4.9.0",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/react-query": "5.100.1",
    "@tanstack/react-query-devtools": "5.100.1",
    "@tanstack/react-table": "8.21.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "docx": "9.6.1",
    "exceljs": "4.4.0",
    "google-auth-library": "10.6.2",
    "pino": "10.3.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-error-boundary": "6.1.1",
    "react-hook-form": "7.73.1",
    "react-router": "7.14.2",
    "shadcn": "4.4.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.4",
    "to-words": "5.5.0",
    "tw-animate-css": "1.4.0",
    "type-fest": "5.6.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@eslint/js": "10.0.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@tanstack/eslint-plugin-query": "5.100.5",
    "@total-typescript/ts-reset": "0.6.1",
    "@tsconfig/node22": "22.0.5",
    "@types/babel__core": "7.20.5",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.5.0",
    "netlify-cli": "25.6.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.3",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2",
